# Шаблон секретів Google Workspace для Edge Functions (schedule-interview, fetch-meet-transcript).
# 1. Скопіюй цей файл у supabase/.secrets.env
# 2. Встав значення з завантаженого JSON-ключа сервісного акаунта:
#      client_email  -> GOOGLE_SA_EMAIL
#      private_key   -> GOOGLE_SA_PRIVATE_KEY (копіюй ЯК Є значення поля private_key
#                       з JSON — довгий блок -----BEGIN...-----END з буквальними \n)
# 3. supabase secrets set --env-file supabase/.secrets.env
# 4. Видали supabase/.secrets.env після застосування (він у .gitignore).

GOOGLE_SA_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nВСТАВ_ЗНАЧЕННЯ_private_key_З_JSON\n-----END PRIVATE KEY-----\n"
